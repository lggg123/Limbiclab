# LLM — CrewAI uses OpenAI by default
OPENAI_API_KEY=sk-...

# Serper — web search for the researcher agent
# Get your key at serper.dev
SERPER_API_KEY=...

# Flask security — set this in Railway, use it as X-Webhook-Secret header
WEBHOOK_SECRET=your-random-secret-here

# Resend — email delivery for newsletter sends
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=LimbicLab <hello@limbiclab.xyz>

# Supabase — subscriber list for /send endpoint
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# LimbicLab site URL — used to generate /store links in newsletter
LIMBICLAB_SITE_URL=https://www.limbiclab.xyz

# Railway sets PORT automatically — do not set manually
PORT=8080
